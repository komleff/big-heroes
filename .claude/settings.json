{
    "permissions": {
        "allow": [
            "Bash(*)",
            "Read",
            "Edit",
            "Write",
            "Glob",
            "Grep",
            "WebFetch",
            "WebSearch",
            "TodoWrite",
            "Task",
            "NotebookEdit"
        ],
        "deny": [
            "Read(.env*)",
            "Read(**/credentials*)",
            "Read(**/secrets*)",
            "Bash(rm -rf *)",
            "Bash(rm -r *)",
            "Bash(rm -fr *)",
            "Bash(rmdir *)",
            "Bash(Remove-Item -Recurse *)",
            "Bash(git push --force *)",
            "Bash(git push -f *)",
            "Bash(git push origin main)",
            "Bash(git push * main)",
            "Bash(git push origin HEAD:main)",
            "Bash(git push * HEAD:main)",
            "Bash(git push origin master)",
            "Bash(git push * master)",
            "Bash(git push origin HEAD:master)",
            "Bash(git push * HEAD:master)",
            "Bash(gh pr merge *)",
            "Bash(gh repo delete *)",
            "Bash(gh api -X DELETE *)"
        ],
        "defaultMode": "bypassPermissions"
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash(git commit*)",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash -c 'npm run test --if-present || (echo \"{\\\"decision\\\": \\\"block\\\", \\\"reason\\\": \\\"Тесты падают. Исправь перед коммитом.\\\"}\" && exit 2)'",
                        "timeout": 120
                    }
                ]
            },
            {
                "matcher": "Bash(gh pr comment*)",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash -c 'BRANCH=$(git branch --show-current); PR=$(gh pr list --head \"$BRANCH\" --json number --jq \".[0].number\" 2>/dev/null); if [ -z \"$PR\" ] || [ \"$PR\" = \"null\" ]; then echo \"БЛОКИРОВКА: PR не найден для ветки $BRANCH. Сначала создай PR через gh pr create.\" >&2; exit 1; fi'"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo 'Файл изменён. Убедись, что тесты проходят перед коммитом.'"
                    }
                ]
            }
        ]
    },
    "env": {
        "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
    },
    "language": "russian",
    "enableAllProjectMcpServers": true,
    "plansDirectory": "./docs/plans"
}
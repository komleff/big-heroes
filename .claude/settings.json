{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "Task",
      "NotebookEdit"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/credentials*)",
      "Read(**/secrets*)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm -fr *)",
      "Bash(rmdir *)",
      "Bash(Remove-Item -Recurse *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push origin main)",
      "Bash(git push * main)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push * HEAD:main)",
      "Bash(git push origin master)",
      "Bash(git push * master)",
      "Bash(git push origin HEAD:master)",
      "Bash(git push * HEAD:master)",
      "Bash(gh pr merge *)",
      "Bash(gh api *merge*)",
      "Bash(gh repo delete *)",
      "Bash(gh api -X DELETE *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/codex-login.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'npm run test --if-present || (echo \"{\\\"decision\\\": \\\"block\\\", \\\"reason\\\": \\\"Тесты падают. Исправь перед коммитом.\\\"}\" && exit 2)'",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "Bash(gh pr comment*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'BRANCH=$(git branch --show-current); PR=$(timeout 10 gh pr list --head \"$BRANCH\" --json number --jq \".[0].number\" 2>/dev/null); if [ -z \"$PR\" ] || [ \"$PR\" = \"null\" ]; then echo \"БЛОКИРОВКА: PR не найден для ветки $BRANCH. Сначала создай PR через gh pr create.\" >&2; exit 1; fi'",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash -c 'HOOK=.claude/hooks/check-merge-ready.py; for cmd in py python3 python; do if command -v \"$cmd\" >/dev/null 2>&1; then if [ \"$cmd\" = \"py\" ]; then \"$cmd\" -3 \"$HOOK\"; else \"$cmd\" \"$HOOK\"; fi; exit $?; fi; done; echo \"БЛОКИРОВКА: Python-интерпретатор не найден (py/python3/python). Hook не может выполниться fail-secure.\" >&2; exit 1'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Файл изменён. Убедись, что тесты проходят перед коммитом.'"
          }
        ]
      }
    ]
  },
  "language": "russian",
  "plansDirectory": "./docs/plans"
}

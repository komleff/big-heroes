node_modules/
dist/
.env
.env.*
*.local

# Claude Code локальные настройки (могут содержать секреты — см. .agents/CODEX_AUTH.md)
.claude/settings.local.json

# Временные git worktrees для параллельных агентских задач
.claude/worktrees/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Windows shortcuts
*.lnk

# macOS
.DS_Store
**/.DS_Store

# Python (артефакты hook-скриптов в .claude/hooks/)
__pycache__/
**/__pycache__/
*.pyc

# External review artifacts (Mode A dogfood output) — не коммитим в ветку,
# raw-вывод моделей публикуется в PR-комментариях, локально только для отладки.
.review-responses/

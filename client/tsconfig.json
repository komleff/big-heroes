{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "outDir": "dist",
        "rootDir": "src",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "paths": {
            "@config/*": ["../config/*"]
        }
    },
    "include": [
        "src"
    ]
}
